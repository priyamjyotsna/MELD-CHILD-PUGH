{
  "expo": {
    "name": "MELD family scores",
    "slug": "easy-liver-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "livertracker",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2B6B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.livertracker.easy-liver-tools",
      "buildNumber": "1",
      "infoPlist": {
        "NSPrivacyAccessedAPITypes": [],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d70a94f1-45c8-42fa-90c1-00a767b243f4"
      },
      "router": {}
    }
  }
}
