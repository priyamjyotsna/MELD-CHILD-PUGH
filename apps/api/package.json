  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@livertracker/clinical-scores": "*",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
